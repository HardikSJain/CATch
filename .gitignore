# CAT Prep Tracker - Git Ignore

# PDFs (large files - use Git LFS if needed)
# Uncomment to track PDFs with Git LFS:
# resources/books/*.pdf
*.pdf

# Flutter/Dart
app/.dart_tool/
app/.packages
app/build/
app/.flutter-plugins
app/.flutter-plugins-dependencies
app/.pub-cache/
app/.pub/

# Android
app/android/**/gradle-wrapper.jar
app/android/.gradle
app/android/captures/
app/android/gradlew
app/android/gradlew.bat
app/android/local.properties
app/android/**/GeneratedPluginRegistrant.java

# iOS
app/ios/**/*.mode1v3
app/ios/**/*.mode2v3
app/ios/**/*.moved-aside
app/ios/**/*.pbxuser
app/ios/**/*.perspectivev3
app/ios/**/*sync/
app/ios/**/.sconsign.dblite
app/ios/**/.tags*
app/ios/**/.vagrant/
app/ios/**/DerivedData/
app/ios/**/Icon?
app/ios/**/Pods/
app/ios/**/.symlinks/
app/ios/**/profile
app/ios/**/xcuserdata
app/ios/.generated/
app/ios/Flutter/App.framework
app/ios/Flutter/Flutter.framework
app/ios/Flutter/Flutter.podspec
app/ios/Flutter/Generated.xcconfig
app/ios/Flutter/app.flx
app/ios/Flutter/app.zip
app/ios/Flutter/flutter_assets/
app/ios/Flutter/flutter_export_environment.sh
app/ios/ServiceDefinitions.json
app/ios/Runner/GeneratedPluginRegistrant.*

# macOS
app/macos/Flutter/GeneratedPluginRegistrant.swift

# Coverage
app/coverage/

# Symbols
app/**/*.dbg.so
app/**/*.ipa
app/**/*.apk

# Exceptions to above rules.
!app/android/**/gradle-wrapper.jar

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Misc
*.log
*.pyc
*.class
.env
.env.local
